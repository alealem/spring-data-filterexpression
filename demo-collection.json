    {
      "name": "Content Items",
      "item": [
        {
          "name": "Search Items By Query Param",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/contents/{{contentId}}/items?q=invoice&page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contents",
                "{{contentId}}",
                "items"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "invoice"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Items By Filter Expression",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operator\": \"and\",\n  \"expressions\": [\n    {\n      \"operator\": \"like\",\n      \"exclude\": false,\n      \"field\": [\"body\", \"text\"],\n      \"value\": \"%Invoice%\",\n      \"caseSensitive\": false\n    },\n    {\n      \"operator\": \"equal\",\n      \"exclude\": false,\n      \"field\": [\"body\", \"type\"],\n      \"value\": \"paragraph\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/contents/{{contentId}}/items/search?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contents",
                "{{contentId}}",
                "items",
                "search"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Items By Filter Expression - Simple",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operator\": \"like\",\n  \"exclude\": false,\n  \"field\": [\"body\", \"text\"],\n  \"value\": \"%meeting%\",\n  \"caseSensitive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/contents/{{contentId}}/items/search?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contents",
